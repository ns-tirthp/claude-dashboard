# Server Configuration
PORT=3001

# Data Paths
CLAUDE_PROJECTS_PATH=~/.claude/projects
TELEMETRY_DB_PATH=./data/telemetry.db
CHAT_DB_PATH=./data/chat.db
DASHBOARD_DB_PATH=./data/dashboard.db

# AI Provider Configuration
# Supported providers: 'claude', 'openai', 'local'
AI_PROVIDER=claude

# Model override (optional - uses provider default if not set)
# Claude: claude-3-5-sonnet-20241022, claude-3-opus-20240229, etc.
# OpenAI: gpt-4, gpt-3.5-turbo, etc.
AI_MODEL=

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (for custom endpoints or proxies)
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Local AI URL (for local models like Ollama)
LOCAL_AI_URL=http://localhost:11434

# Chat Configuration
# Maximum number of rows to return from chat queries
CHAT_ROW_LIMIT=500

# OTLP Receiver Debug
# Set to 'true' to enable debug logging for OTLP telemetry receiver
OTLP_DEBUG=false

# Ingestor Configuration
# Set to 'false' to disable automatic JSONL file ingestion
ENABLE_INGESTOR=true
