# Backend Configuration
PORT=3001
NODE_ENV=production

# Persistent SQLite path used by the OTel receiver.
# In Docker this lives on the claude-dashboard-data volume.
# TELEMETRY_DB_PATH=/app/data/telemetry.db

# Set to 1 to log every received OTLP payload size (verbose).
# OTLP_DEBUG=1

# Frontend Configuration (for production builds)
VITE_API_URL=http://localhost:3001

# Claude Projects Path (default: ~/.claude/projects)
# CLAUDE_PROJECTS_PATH=/custom/path/to/claude/projects

# ---------------------------------------------------------------
# Claude Code OTel exporter (set these in YOUR shell, not here)
# ---------------------------------------------------------------
# CLAUDE_CODE_ENABLE_TELEMETRY=1
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/json
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3001
# OTEL_METRIC_EXPORT_INTERVAL=10000
